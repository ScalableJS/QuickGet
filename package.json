{
  "name": "quickget-remote",
  "version": "2.9.0",
  "description": "Lightweight client for QNAP Download Station 5",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e:mock": "playwright test tests/e2e/mockNas.contract.spec.ts tests/e2e/popup.full-cycle.spec.ts",
    "test:e2e:mock:headed": "playwright test tests/e2e/mockNas.contract.spec.ts tests/e2e/popup.full-cycle.spec.ts --headed",
    "test:e2e:real": "QNAP_E2E_REAL=1 playwright test tests/e2e/popup.real-nas.spec.ts --grep-invert @mutating",
    "test:e2e:real:mutating": "QNAP_E2E_REAL=1 QNAP_E2E_ALLOW_MUTATIONS=1 playwright test tests/e2e/popup.real-nas.spec.ts --grep @mutating",
    "generate-icons": "node scripts/generate-icons.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "release": "npm run build && npx bestzip quickget-remote-${npm_package_version}.zip dist/*",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepare": "husky"
  },
  "keywords": [
    "qnap",
    "download-station",
    "browser-extension",
    "chrome-extension",
    "firefox-addon"
  ],
  "author": "QuickGet Remote Contributors",
  "license": "CC-BY-NC-SA-4.0",
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.2.0",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/html-vite": "^8.6.14",
    "@storybook/test": "^8.6.14",
    "@types/chrome": "^0.0.268",
    "@types/node": "^24.8.1",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "bestzip": "^2.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-import": "^2.29.1",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "msw": "^2.12.10",
    "prettier": "^3.3.0",
    "sharp": "^0.34.4",
    "storybook": "^8.6.14",
    "typescript": "^5.3.3",
    "vite": "^5.1.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "morphdom": "^2.7.7",
    "openapi-fetch": "^0.9.4"
  }
}
