{
  "name": "quickget-remote",
  "version": "2.9.0",
  "description": "Lightweight client for QNAP Download Station 5",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e:mock": "playwright test tests/e2e/mockNas.contract.spec.ts tests/e2e/popup.full-cycle.spec.ts",
    "test:e2e:mock:headed": "playwright test tests/e2e/mockNas.contract.spec.ts tests/e2e/popup.full-cycle.spec.ts --headed",
    "test:e2e:real": "QNAP_E2E_REAL=1 playwright test tests/e2e/popup.real-nas.spec.ts --grep-invert @mutating",
    "test:e2e:real:mutating": "QNAP_E2E_REAL=1 QNAP_E2E_ALLOW_MUTATIONS=1 playwright test tests/e2e/popup.real-nas.spec.ts --grep @mutating",
    "generate-icons": "node scripts/generate-icons.js",
    "typecheck": "tsc --noEmit",
    "check:svelte": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "release": "npm run build && npx bestzip quickget-remote-${npm_package_version}.zip dist/*",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepare": "husky"
  },
  "keywords": [
    "qnap",
    "download-station",
    "browser-extension",
    "chrome-extension",
    "firefox-addon"
  ],
  "author": "QuickGet Remote Contributors",
  "license": "CC-BY-NC-SA-4.0",
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@crxjs/vite-plugin": "^2.7.0",
    "@iconify-json/lucide": "^1.2.113",
    "@playwright/test": "^1.61.0",
    "@storybook/svelte": "^10.4.6",
    "@storybook/svelte-vite": "^10.4.6",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/chrome": "^0.1.43",
    "@types/node": "^24.13.2",
    "@vitest/coverage-v8": "^4.1.9",
    "bestzip": "^2.0.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "sharp": "^0.34.5",
    "storybook": "^10.4.6",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "typescript": "^5.3.3",
    "unplugin-icons": "^23.0.1",
    "vite": "^7.1.12",
    "vitest": "^4.1.9",
    "@storybook/addon-docs": "^10.4.6"
  },
  "dependencies": {
    "openapi-fetch": "^0.9.4"
  }
}
